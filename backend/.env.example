SECRET_KEY="generate-a-secure-random-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# Database Configuration
POSTGRES_USER="your_db_user"
POSTGRES_PASSWORD="your_secure_db_password"
POSTGRES_DB="your_db_name"
DATABASE_URL="postgresql://your_db_user:your_secure_db_password@db:5432/your_db_name"

# Default Admin Seed Credentials
ADMIN_USERNAME="your_admin_username"
ADMIN_PASSWORD="your_admin_password"

# CORS: Set to your deployed frontend URL in production.
# Leave empty for local development (allows all origins).
FRONTEND_URL=""
